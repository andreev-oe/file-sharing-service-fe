{
  "name": "file-sharing-service-fe",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --base=/",
    "preview": "vite preview",
    "prepare": "husky",
    "lint": "eslint src --ignore-path .gitignore",
    "lint:fix": "yarn run lint --fix",
    "lint:staged": "eslint --ignore-path .gitignore",
    "check-types": "tsc --project tsconfig.json --pretty --noEmit",
    "api:fetch": "curl -o src/api/api.json http://localhost:3000/api/docs-json",
    "api:generate": "rimraf src/api/generated && orval",
    "api:update": "yarn run api:fetch && yarn run api:generate"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@hookform/resolvers": "^3.3.4",
    "@mui/icons-material": "^6.1.7",
    "@mui/lab": "^6.0.0-beta.16",
    "@mui/material": "^6.1.7",
    "@tanstack/react-query": "^5.32.0",
    "@tanstack/react-query-devtools": "^5.32.0",
    "axios": "^1.6.8",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.11",
    "nanoid": "^5.0.7",
    "notistack": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^4.0.13",
    "react-helmet-async": "^2.0.4",
    "react-hook-form": "^7.51.3",
    "react-router-dom": "6.27.0",
    "zod": "^3.23.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.2",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "8",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-check-file": "^2.8.0",
    "eslint-plugin-custom": "file:packages/eslint-plugin-custom",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.0.11",
    "js-cookie": "^3.0.5",
    "lint-staged": "^15.2.2",
    "orval": "^7.3.0",
    "prettier": "^3.2.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vite-tsconfig-paths": "^4.3.2"
  },
  "lint-staged": {
    "*.+(ts|tsx)": [
      "yarn lint:staged",
      "bash -c 'yarn check-types'"
    ]
  }
}
